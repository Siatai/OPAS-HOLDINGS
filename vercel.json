{
  "buildCommand": "node scripts/build-vercel.mjs",
  "outputDirectory": "dist/vercel",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/opas-investor-deck(?:/.*)?$",
      "dest": "/opas-investor-deck/index.html"
    },
    {
      "src": "^/opas-customer-deck(?:/.*)?$",
      "dest": "/opas-customer-deck/index.html"
    },
    {
      "src": "^/opas-overview-deck(?:/.*)?$",
      "dest": "/opas-overview-deck/index.html"
    },
    {
      "src": "^/(?!opas-investor-deck(?:/|$)|opas-customer-deck(?:/|$)|opas-overview-deck(?:/|$)).*$",
      "dest": "/index.html"
    }
  ]
}
